# Environment Configuration

# This file can be copied to .env.local and populated automatically using
# the `scripts/setup-env.ps1` helper (see README).

# Database Configuration (used by the Next.js backend)
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=
# DB_NAME=college_db

# API Configuration
# This is the base URL used by the frontend when talking to the backend.
# By default it points at the same server, but you can override it in production.
# NEXT_PUBLIC_API_URL=http://localhost:3000/api
# NEXT_PUBLIC_USE_API=true            # enable real API (otherwise mock data is used)

# Feature Flags
# NEXT_PUBLIC_ENABLE_AI_COACH=true
# NEXT_PUBLIC_ENABLE_REPORTS=true

# Analytics (optional)
# NEXT_PUBLIC_GA_ID=

# Theme
# NEXT_PUBLIC_DEFAULT_THEME=system
